{
  "name": "claudix-vscode",
  "displayName": "Claudix - Claude Code for VSCode",
  "description": "Claude Code for VSCode. Bring the power of Claude AI assistant directly into your coding environment.",
  "version": "0.4.88",
  "publisher": "Haleclipse",
  "engines": {
    "vscode": "^1.98.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "icon": "resources/claude-logo.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "configuration": {
      "title": "Claudix",
      "properties": {
        "claudix.openClaudeCodeSettings": {
          "type": "null",
          "markdownDescription": "**Configure Claude Code Settings**\n\nClick here to open: [**Open Claude Code Settings**](command:claudix.openSettings)\n\n---\n\nThe Claude Code Settings page allows you to configure:\n- Profiles & Model Selection\n- MCP Servers & Plugins\n- Permissions & Sandbox\n- Memory, Rules & Advanced Options\n\nNote: Claudix extension settings are managed here in VSCode settings.",
          "order": 0
        },
        "claudix.defaultPermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "plan"
          ],
          "default": "default",
          "enumItemLabels": [
            "Default",
            "Agent",
            "Plan"
          ],
          "enumDescriptions": [
            "Prompt for permission on first use of each operation",
            "Automatically accept file edits and common operations",
            "Read-only mode, Claude can explore but not modify files"
          ],
          "description": "Default permission mode for new sessions",
          "order": 1
        },
        "claudix.defaultThinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "extended"
          ],
          "default": "on",
          "enumItemLabels": [
            "Off",
            "On",
            "Extended"
          ],
          "description": "Default extended thinking level for new sessions",
          "order": 2
        },
        "claudix.disableFunSpinner": {
          "type": "boolean",
          "default": false,
          "description": "Disable fun rotating verbs while Claude is working. When enabled, shows plain 'Working...' instead of fun verbs like 'Reticulating...', 'Spelunking...', etc.",
          "order": 3
        },
        "claudix.continueLastSession": {
          "type": "boolean",
          "default": false,
          "description": "Automatically resume the last session when Claudix starts instead of creating a new one",
          "order": 4
        },
        "claudix.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications and messages from Claudix",
          "order": 5
        },
        "claudix.enableContextModeTools": {
          "type": "boolean",
          "default": false,
          "description": "Enable context-mode tools (mdx__context-mode__**) for Claude SDK",
          "order": 6
        },
        "claudix.expandToolOutput": {
          "type": "boolean",
          "default": true,
          "description": "Expand tool output by default. When disabled, tool results start collapsed and must be clicked to expand.",
          "order": 7
        },
        "claudix.showThinking": {
          "type": "boolean",
          "default": false,
          "description": "Show Claude's internal thinking blocks in the chat. When disabled, thinking is hidden and only the final response is shown.",
          "order": 8
        },
        "claudix.configurationDirectory": {
          "type": "string",
          "default": "",
          "description": "Path to the Claude configuration directory. Leave empty to use CLAUDE_CONFIG_DIR environment variable or default (~/.claude)",
          "order": 7
        },
        "claudix.environmentVariables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment variable name"
              },
              "value": {
                "type": "string",
                "description": "Environment variable value"
              }
            },
            "required": [
              "name",
              "value"
            ]
          },
          "default": [],
          "description": "Environment variables to set when launching Claude"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudix-chat-sidebar",
          "title": "Claudix",
          "icon": "resources/claude-logo.svg"
        }
      ]
    },
    "views": {
      "claudix-chat-sidebar": [
        {
          "icon": "resources/claude-logo.svg",
          "type": "webview",
          "id": "claudix.sessionList",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudix.showChat",
        "title": "Show Claudix"
      },
      {
        "command": "claudix.openSettings",
        "title": "Claudix: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "claudix.newSession",
        "title": "Claudix: New Chat"
      },
      {
        "command": "claudix.clearSession",
        "title": "Claudix: Clear Session"
      },
      {
        "command": "claudix.closeSession",
        "title": "Claudix: Close Chat Panel"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+n",
        "mac": "cmd+n",
        "command": "claudix.newSession",
        "when": "claudixFocused"
      },
      {
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "command": "claudix.clearSession",
        "when": "claudixFocused"
      },
      {
        "key": "ctrl+w",
        "mac": "cmd+w",
        "command": "claudix.closeSession",
        "when": "claudixFocused"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudix.openSettings",
          "when": "view == claudix.sessionList",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:webview\" \"pnpm run watch:extension\"",
    "dev:webview": "vite --config src/webview/vite.config.ts --port 5173 --strictPort",
    "build:extension": "tsx esbuild.ts --production",
    "build:webview": "vite build --config src/webview/vite.config.ts",
    "build": "pnpm run build:webview && pnpm run build:extension",
    "watch:extension": "tsx esbuild.ts --watch",
    "watch:webview": "vite build --config src/webview/vite.config.ts --watch",
    "watch": "concurrently \"pnpm run watch:extension\" \"pnpm run watch:webview\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:webview": "vue-tsc -p src/webview/tsconfig.json --noEmit",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:webview",
    "prepackage": "pnpm run build && cp README.md README.md.bak && sed -i '' 's|https://awesome.re/mentioned-badge.svg|assets/mentioned-badge.png|g' README.md",
    "package": "vsce package --no-dependencies",
    "postpackage": "mv README.md.bak README.md",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue}\" && eslint src --ext ts,tsx,vue --fix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1",
    "vue-vine": "^1.7.27"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@anthropic-ai/sdk": "^0.71.2",
    "@gn8/alien-signals-vue": "^0.1.1",
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@vscode/codicons": "^0.0.44",
    "@vueuse/core": "^14.1.0",
    "alien-signals": "^3.1.2",
    "fuse.js": "^7.1.0",
    "lexical": "^0.39.0",
    "lexical-vue": "^0.14.1",
    "marked": "^17.0.1",
    "motion-v": "^1.7.4",
    "path-browserify-esm": "^1.0.6",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "vue": "^3.5.26",
    "zod": "^3.25.76"
  },
  "keywords": [
    "vscode",
    "extension",
    "claude",
    "ai",
    "coding-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Haleclipse/Claudix"
  },
  "license": "AGPL-3.0"
}
